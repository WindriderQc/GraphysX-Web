    "smoke:standalone": "node scripts/smoke-standalone.mjs",
    "smoke:levels": "node scripts/smoke-levels.mjs",
    "smoke:foundation": "node scripts/smoke-foundation.mjs",
    "serve:staging": "node scripts/staging-server.mjs",
    "agent:stdio": "node tools/graphysx-agent-stdio.mjs --stdio",
    "agent:manifest": "node tools/graphysx-agent-stdio.mjs",
    "qa": "node scripts/qa-r6.mjs",
    "qa:nature": "node scripts/qa-nature-gallery.mjs",
    "qa:agent-world": "node scripts/qa-agent-world.mjs",
