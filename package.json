{
  "name": "graphysx-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "smoke:showroom": "node scripts/smoke-showroom.mjs",
    "smoke:editor": "node scripts/smoke-editor.mjs",
    "smoke:standalone": "node scripts/smoke-standalone.mjs",
    "smoke:levels": "node scripts/smoke-levels.mjs",
    "smoke:foundation": "node scripts/smoke-foundation.mjs",
    "probe:terrain": "node scripts/probe-terrain-rest.mjs",
    "probe:water-cost": "node scripts/probe-water-cost.mjs",
    "smoke:scene-store": "node scripts/smoke-scene-store.mjs",
    "smoke:triggers": "node scripts/smoke-triggers.mjs",
    "smoke:roundtrip": "node scripts/smoke-roundtrip.mjs",
    "smoke:rules": "node scripts/smoke-rules.mjs",
    "serve:staging": "node scripts/staging-server.mjs",
    "serve:scenes": "node server/scene-store.mjs",
    "scene": "node tools/graphysx-scene-agent.mjs",
    "agent:stdio": "node tools/graphysx-agent-stdio.mjs --stdio",
    "agent:manifest": "node tools/graphysx-agent-stdio.mjs",
    "assets:manifest": "node scripts/product-assets.mjs",
    "qa": "node scripts/qa-agent-entities.mjs"
  },
  "dependencies": {
    "cannon-es": "^0.20.0",
    "three": "^0.179.1"
  },
  "devDependencies": {
    "@types/three": "^0.179.0",
    "playwright": "^1.60.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.16"
  }
}

