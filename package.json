    "cannon-es": "^0.20.0",
    "three": "^0.179.1"
  },
  "devDependencies": {
    "@types/three": "^0.179.0",
    "playwright": "^1.60.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.16"
  }
