{
  "name": "graphysx-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "smoke:showroom": "node scripts/smoke-showroom.mjs",
    "smoke:editor": "node scripts/smoke-editor.mjs",
    "smoke:standalone": "node scripts/smoke-standalone.mjs",
    "smoke:levels": "node scripts/smoke-levels.mjs",
    "smoke:foundation": "node scripts/smoke-foundation.mjs",
    "probe:terrain": "node scripts/probe-terrain-rest.mjs",
    "probe:rapier-heightfield": "node scripts/probe-rapier-heightfield.mjs",
    "probe:rapier-materials": "node scripts/probe-rapier-material-parity.mjs",
    "probe:water-cost": "node scripts/probe-water-cost.mjs",
    "smoke:scene-store": "node scripts/smoke-scene-store.mjs",
    "smoke:triggers": "node scripts/smoke-triggers.mjs",
    "smoke:roundtrip": "node scripts/smoke-roundtrip.mjs",
    "smoke:rules": "node scripts/smoke-rules.mjs",
    "smoke:media": "node scripts/smoke-media.mjs",
    "smoke:physics": "node scripts/smoke-physics.mjs",
    "smoke:mesh-colliders": "node scripts/smoke-mesh-colliders.mjs",
    "smoke:rapier-race": "node scripts/smoke-rapier-race.mjs",
    "smoke:store-auth": "node scripts/smoke-store-auth.mjs",
    "smoke:dna": "node scripts/smoke-dna.mjs",
    "serve:staging": "node scripts/staging-server.mjs",
    "serve:scenes": "node server/scene-store.mjs",
    "scene": "node tools/graphysx-scene-agent.mjs",
    "agent:stdio": "node tools/graphysx-agent-stdio.mjs --stdio",
    "agent:manifest": "node tools/graphysx-agent-stdio.mjs",
    "assets:manifest": "node scripts/product-assets.mjs",
    "assets:slide-large": "node scripts/vendor-slide-large.mjs && node scripts/build-asset-catalog.mjs",
    "assets:shelf-thumbnails": "node scripts/capture-shelf-thumbnails.mjs",
    "qa": "node scripts/qa-agent-entities.mjs"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.19.3",
    "@fontsource/space-grotesk": "^5.3.0",
    "three": "^0.179.1"
  },
  "devDependencies": {
    "@types/three": "^0.179.0",
    "playwright": "^1.60.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.16"
  }
}
